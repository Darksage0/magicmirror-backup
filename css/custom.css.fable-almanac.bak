/* ============================================================
   MagicMirror² — custom.css
   PORTRAIT layout — 1080 × 1920 (21.5" monitor rotated 90°)

   DESIGN — "midnight almanac"
   The mirror already IS an almanac: sunrise, weather, holy
   days, three months of calendar, the day's news. This design
   leans into it — a cool, moonlit nautical almanac consulted
   at night in a dark hallway. Blue-black ground so the panel
   dissolves into the glass; cool paper-white ink; ONE accent,
   moonlight blue, reserved for headers, the today-pill, the
   notable-day marks and rain (water is blue); coral is the
   lone warm note, marking weekends and holidays the way an
   almanac prints its red-letter days. Engineered single-weight
   display digits (Unica One) for the two hero readouts; a
   bookish screen serif (Spectral) for every written word.
   Panels are framed by almanac-style DOUBLE RULES under their
   headers — no boxed cards.

   Top → bottom:
     1. Flip clock + date  (top_bar, centered, enlarged)
     2. Weather | Notable Days  (top_left / top_right pair)
     3. Multi-month calendar  (upper_third, full-width row)
     4. Newsfeed ticker  (bottom_bar, lifted above photos)
     5. Photo slideshow  (fullscreen_below, bottom band,
        edge-to-edge width, aspect ratio preserved)
   ============================================================ */


/* ─────────────────────────────────────────
   0. TYPE — self-hosted (see fonts/custom/).
      Unica One: engineered condensed display, hero readouts
      only (clock digits, temperature).
      Spectral: cool bookish serif for all running text.
   ───────────────────────────────────────── */
@font-face {
  font-family: "Unica One";
  font-style: normal;
  font-weight: 400;
  font-display: swap;
  src: url("fonts/unica-one.woff2") format("woff2");
}
@font-face {
  font-family: "Spectral";
  font-style: normal;
  font-weight: 300;
  font-display: swap;
  src: url("fonts/spectral-light.woff2") format("woff2");
}
@font-face {
  font-family: "Spectral";
  font-style: normal;
  font-weight: 400;
  font-display: swap;
  src: url("fonts/spectral.woff2") format("woff2");
}
@font-face {
  font-family: "Spectral";
  font-style: normal;
  font-weight: 600;
  font-display: swap;
  src: url("fonts/spectral-semibold.woff2") format("woff2");
}
@font-face {
  font-family: "Spectral";
  font-style: italic;
  font-weight: 400;
  font-display: swap;
  src: url("fonts/spectral-italic.woff2") format("woff2");
}


/* ─────────────────────────────────────────
   1. GLOBAL TOKENS  (viewport-relative)
   ───────────────────────────────────────── */
:root {
  /* uniform 5px frame around the entire mirror */
  --gap-body-top:    5px;
  --gap-body-right:  5px;
  --gap-body-bottom: 5px;
  --gap-body-left:   5px;

  --gap-modules: 1.2vh;

  /* ≈ 21px at 1920px height */
  --font-size: 1.1vh;

  /* ---- palette: moonlit almanac on dark glass ---- */
  --ground:      #070a0e;  /* blue-black, dissolves into mirror  */
  --ink:         #e9eef4;  /* cool paper-white — primary text    */
  --ink-dim:     #8291a1;  /* slate — secondary text             */
  --moon:        #4890c8;  /* THE accent: headers, today, marks, rain */
  --moon-rule:   #23415c;  /* recessed double-rule / frame color */
  --red-letter:  #c2604e;  /* weekends & holidays — almanac red-letter days */

  /* re-theme MagicMirror's own tokens so every default module
     (weather, calendar, newsfeed…) picks this up automatically */
  --color-background:  var(--ground);
  --color-text:         var(--ink-dim);
  --color-text-dimmed:  var(--ink-dim);
  --color-text-bright:  var(--ink);
  --font-primary:   "Spectral";
  --font-secondary: "Spectral";
  --font-display:   "Unica One";

  --image-radius: 1.2vw;

  /* Portrait layout bands (tune here).
     Values chosen so every section gap = --section-gap:
     date→cards, cards→calendar, calendar→news, news→photo. */
  --section-gap:   1.042vh;  /* = 20px at 1920 — keep vh so it renders
                                the same on any viewport size */
  --photo-height:  40.3%; /* photo band height from bottom  */
  --calendar-top:  36.4%; /* top edge of multi-month band   */
}

/* lining, tabular figures everywhere — Spectral's proportional
   old-style figures are wrong for a clock/calendar/mirror */
body {
  font-variant-numeric: lining-nums tabular-nums;
}


/* ─────────────────────────────────────────
   2. PANEL HEADERS — the only framing device.
      Almanac-style double rule below letter-spaced
      small caps; replaces the boxed-card look.
   ───────────────────────────────────────── */
header {
  font-family: "Spectral", serif;
  font-weight: 600;
  font-size: 0.82rem;
  letter-spacing: 0.2em;
  color: var(--moon);
  border-bottom: 4px double var(--moon-rule);
  line-height: 1.2;
  padding-bottom: 0.5vh;
  margin-bottom: 0.9vh;
}


/* ─────────────────────────────────────────
   3. FLIP CLOCK — top bar, centered, big
   ───────────────────────────────────────── */
.region.top.bar {
  text-align: center;
}

.region.top.bar .module.MMM-FlipClock {
  display: inline-block;
  margin-bottom: 0.5vh;
}

/* The tick library sizes digits at 5em of this wrapper, so this
   value is the overall clock scale: 1.43 × base width (~750px)
   makes the digit cards span the full 1070px frame width. */
.MMM-FlipClock .tick {
  font-size: 1.43rem !important;
  font-family: var(--font-display) !important;
}

/* Cold slate flap housing — a station clock at night. */
.MMM-FlipClock .tick-flip-panel {
  background-color: #101720 !important;
  color: var(--ink) !important;
}
.MMM-FlipClock .tick-text-inline {
  color: var(--ink-dim) !important;
}
.MMM-FlipClock .tick-label {
  color: var(--ink-dim) !important;
  font-family: "Spectral", serif;
  letter-spacing: 0.08em;
}

/* The empty updatenotification module above the clock still
   carries a --gap-modules bottom margin (measured 21px) —
   drop it while the module has no content so the clock hugs
   the 5px top frame. When an update notice appears, the
   margin comes back automatically. */
.region.top.bar .module.updatenotification:not(:has(.module-content div:not(:empty))) {
  margin-bottom: 0;
}


/* ─────────────────────────────────────────
   4. WEATHER + NOTABLE DAYS — side-by-side,
      framed only by their headers' double
      rules. Edges aligned to the 5px body
      frame, 10px gutter between panels.
   ───────────────────────────────────────── */
.region.top.left  { width: calc(50vw - 10px); }
.region.top.right { width: calc(50vw - 10px); }

.region.top.left .module,
.region.top.right .module,
.region.upper.third .module.MMM-Multimonth {
  border: none;
  border-radius: 0;
  padding: 0 0.4vw;
  background: transparent;
  box-sizing: border-box;
  width: 100%;
}

/* Date line (default clock module, date-only) — Spectral italic,
   the almanac's own hand. */
.region.top.bar .module.clock {
  margin-bottom: var(--section-gap);
}
.region.top.bar .clock .date {
  font-family: "Spectral", serif;
  font-style: italic;
  font-weight: 400;
  font-size: 1.5rem;
  color: var(--ink);
}

/* Weather — hero temperature in the display face; wind, sun and
   feels-like stay in quiet slate so the one number keeps its weight. */
.weather .type-temp > span.bright {
  font-family: var(--font-display);
  font-weight: 400;   /* Unica One ships a single weight */
}
.weather .wi.dimmed,
.weather .feelslike .dimmed {
  color: var(--ink-dim);
}
/* rain-family icons take the moon accent — water is blue */
.weather .wi-rain,
.weather .wi-showers,
.weather .wi-thunderstorm,
.weather .wi-sleet,
.weather .wi-snow,
.weather .wi-day-rain,
.weather .wi-night-rain,
.weather .wi-day-showers,
.weather .wi-night-showers {
  color: var(--moon);
}

/* Notable Days (calendar module) */
.calendar td.symbol {
  color: var(--moon);
}
.calendar td.title {
  font-family: "Spectral", serif;
  color: var(--ink);
}
.calendar td.time {
  color: var(--ink-dim);
  font-variant-numeric: lining-nums tabular-nums;
}


/* ─────────────────────────────────────────
   5. MULTI-MONTH CALENDAR — full-width band
   ───────────────────────────────────────── */
.region.upper.third {
  top: var(--calendar-top);
  transform: none;          /* main.css centers thirds with translateY(-50%) — cancel it */
  left: var(--gap-body-left);
  right: var(--gap-body-right);
  width: auto;
  text-align: center;
}

.region.upper.third .module.MMM-Multimonth {
  display: block;    /* full-width card, edges aligned with the pair above */
}


/* ─────────────────────────────────────────
   6. NEWSFEED — single-line running ticker
      just above the photos
   ───────────────────────────────────────── */
.region.bottom.bar {
  /* 5px frame + one section gap above the photo band */
  bottom: calc(var(--photo-height) + 5px + var(--section-gap));
  overflow: hidden;
}

.newsfeed .module-content {
  overflow: hidden;
  width: 100%;
}

/* One marquee line: starts off-screen right (padding-left: 100%
   = parent width), scrolls fully off the left edge. Duration must
   match the module's updateInterval (18 s) so each headline makes
   exactly one pass before the next one starts. */
.newsfeed .module-content > div {
  display: inline-block;
  white-space: nowrap;
  padding-left: 100%;
  animation: news-ticker 18s linear infinite;
  will-change: transform;
}

.newsfeed .newsfeed-source,
.newsfeed .newsfeed-title {
  display: inline;
  font-family: "Spectral", serif;
}
.newsfeed .newsfeed-source {
  color: var(--ink-dim);
  font-style: italic;
}
.newsfeed .newsfeed-title {
  color: var(--ink);
}

@keyframes news-ticker {
  from { transform: translateX(0); }
  to   { transform: translateX(-100%); }
}


/* ─────────────────────────────────────────
   7. PHOTO SLIDESHOW — bottom band, edge to edge
   ───────────────────────────────────────── */
.region.fullscreen.below {
  inset:  unset !important;
  top:    auto !important;
  right:  auto !important;

  position: fixed !important;
  left:     5px !important;
  bottom:   5px !important;

  width:  calc(100vw - 10px) !important;
  height: var(--photo-height) !important;

  background: transparent !important;
  border: 1px solid var(--moon-rule);
  border-radius: var(--image-radius);
  box-sizing: border-box !important;
  overflow: hidden !important;
  z-index: 0;
}

.MMM-Wallpaper .content-fill {
  width:  100% !important;
  height: 100% !important;

  display:         flex !important;
  flex-direction:  row !important;
  justify-content: center !important;   /* photos centered in the band */
  align-items:     flex-end !important; /* flush with screen bottom    */

  background: transparent !important;
}

.MMM-Wallpaper img {
  width:      auto !important;
  height:     auto !important;
  max-width:  100% !important;
  max-height: 100% !important;

  object-fit: contain !important;       /* keep aspect ratio */

  margin:  0 !important;
  display: block !important;
  filter:  none !important;

  border-radius: var(--image-radius) !important;
}


/* ─────────────────────────────────────────
   8. MULTIMONTH CALENDAR THEMING
   ───────────────────────────────────────── */
.MMM-Multimonth .settings {
  --background-header:   transparent;
  --background-dow:      transparent;
  --background-dowBlank: transparent;
  --background-weekno:   transparent;
  --background-event:    transparent;

  --color-header:  var(--ink);
  --color-dow:     var(--ink-dim);
  --color-weekno:  var(--ink-dim);

  --background-weekday: transparent;
  --background-weekend: transparent;
  --color-weekend:      var(--red-letter);

  --background-today: var(--moon);
  --color-today:      var(--ground);

  --back-rounding:    8px;
  --alignment:        center;
  --fontsize:         var(--font-size-small);
  --smallEventMarker: 4px;
}

.MMM-Multimonth .dayContainer {
  display: flex;
  flex-flow: row wrap;
  flex: 1 0;
  position: relative; /* creates positioning context */
}

.MMM-Multimonth .events {
  display: none !important;  /* Hide the dots completely */
}

/* ── Even grid: every day cell has identical, fixed geometry.
      A permanent transparent 2px border reserves the highlight
      space, so today/event styling changes COLOR only — cell
      size and row spacing never shift. ── */
.MMM-Multimonth .day {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 1.75em;
  box-sizing: border-box;
  border: 2px solid transparent;
  border-radius: var(--back-rounding);
  font-variant-numeric: lining-nums tabular-nums;
}

/* consistent breathing room between rows and between months */
.MMM-Multimonth .weekContainer {
  margin: 1px 0;
  flex: 0 0 auto;   /* natural row height — don't stretch to fill */
}
.MMM-Multimonth .month {
  padding: 0 0.6vw;
  justify-content: flex-start;  /* top-align; a 6-week month (e.g. August)
                                   just extends lower with the SAME row
                                   rhythm instead of squeezing its rows */
}

/* Event indicator — hollow moonlight outline (same hue family as
   the today-fill, lower intensity = lower priority) */
.MMM-Multimonth .dayContainer:has(.event) .day {
  border-color: rgba(72, 144, 200, 0.55) !important;
  background-color: transparent !important;
}

/* Today — filled pill, same geometry (module CSS uses
   border-style: hidden which would collapse the border) */
.MMM-Multimonth .today {
  border-style: solid;
  border-color: transparent;
  background-color: var(--background-today);
  color: var(--color-today);
}

/* Today wins over the event outline when both apply */
.MMM-Multimonth .dayContainer:has(.event) .day.today {
  background-color: var(--background-today) !important;
  border-color: transparent !important;
}
